# Optional: base URL for the Veritas API. Used when you don't pass base_url to VeritasClient().
# Unset = production (https://veritas-api.onrender.com/v1). Set for local or staging.
# VERITAS_API_URL=http://localhost:8000/v1

# API key is passed to VeritasClient(api_key="..."). You can load it from env in your code:
#   import os
#   client = VeritasClient(api_key=os.environ["VERITAS_API_KEY"])
# Then set VERITAS_API_KEY in your app's .env (do not commit real keys).
